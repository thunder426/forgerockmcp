# Ops/stack config. Loaded by ops/scripts/lib.sh.
#
# Runtime config (AM creds, shared auth token) lives elsewhere:
#   - mcp-server/env/.env: server runtime
#   - agent/env/.env:      agent runtime
# ops scripts write into both files at install/bootstrap time.

# ---------- Stack ----------
PLATFORM_VERSION=8.1.0
FORGEOPS_REF=2025.2.1
FORGEOPS_DIR=.cache/forgeops

# ---------- Minikube ----------
MINIKUBE_PROFILE=forgerockmcp
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=10g
MINIKUBE_DISK=40g
MINIKUBE_DRIVER=docker

# ---------- Cluster / Hostname ----------
NAMESPACE=identity
FQDN=forgeops.example.com

# ---------- AM admin (ops uses this only to read the generated password and
# hand it off to the server. Server reads AM_BASE_URL etc. from its own .env) ----------
AM_ADMIN_USER=amadmin

# ---------- MCP admin (created by bootstrap-mcp-admin.sh) ----------
MCP_ADMIN_USER=mcp-admin
MCP_ADMIN_PASSWORD=McpAdmin#Local2026!Strong   # AM default policy: ≥8 chars, mixed case, digit, symbol
MCP_ADMIN_PRIVILEGE=ui-realm-admin

# ---------- IDM ----------
IDM_ADMIN_USER=openidm-admin
