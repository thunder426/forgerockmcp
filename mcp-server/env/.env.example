# MCP server runtime config. Copy to mcp-server/env/.env and fill in.
#
# This file belongs to the SERVER side only. The agent must NOT have access to
# it (and vice versa: the server must not read agent/env/.env). The two sides
# share a secret (MCP_SERVER_TOKEN ↔ FORGEROCK_AGENT_TOKEN) but each holds its
# own copy independently.
#
# In dev, ops/scripts/up.sh and ops/scripts/gen-token.sh populate the AM
# credentials and the shared token. In prod, the operator provisions both
# sides through whatever secret-management mechanism they use (k8s Secret,
# systemd unit env, vault, etc.).

# ---------- AM (where the server talks to ForgeRock AM) ----------
AM_BASE_URL=https://forgeops.example.com/am
AM_REALM=root                        # ForgeOps 2025.2.1 only configures root by default; create alpha via the MCP itself.
AM_ADMIN_USER=amadmin
AM_INSECURE_TLS=true                 # accept the self-signed ForgeOps cert; never set true in prod
# AM_ADMIN_PASSWORD is generated by forgeops at install time. Write it here:
#   kubectl get secret am-env-secrets -n identity -o jsonpath='{.data.AM_PASSWORDS_AMADMIN_CLEAR}' | base64 -d
AM_ADMIN_PASSWORD=

# ---------- MCP server auth (gates who can call the MCP) ----------
# MCP_AUTH_MODE values:
#   - static (default): MCP_SERVER_TOKEN must be set; constant-time per-call compare.
#   - oauth-am (NOT IMPLEMENTED): bearer per call, introspected via AM, scope-checked.
#   - disabled (TESTING ONLY): also requires MCP_AUTH_DISABLED_ACK=true.
MCP_AUTH_MODE=static
# Shared secret. Generate with: openssl rand -base64 24 | tr -d '+/='
# The agent must know the SAME value (stored on its side as FORGEROCK_AGENT_TOKEN
# in agent/env/.env). ops/scripts/gen-token.sh writes both halves in dev.
MCP_SERVER_TOKEN=
