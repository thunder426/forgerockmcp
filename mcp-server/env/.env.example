# MCP server runtime config. Copy to mcp-server/env/.env and fill in.
#
# This file belongs to the SERVER side only. The agent must NOT have access to
# it (and vice versa: the server must not read agent/env/.env). The two sides
# share a secret (MCP_SERVER_TOKEN ↔ FORGEROCK_AGENT_TOKEN) but each holds its
# own copy independently.
#
# In dev, ops/scripts/up.sh and ops/scripts/gen-token.sh populate the AM
# credentials and the shared token. In prod, the operator provisions both
# sides through whatever secret-management mechanism they use (k8s Secret,
# systemd unit env, vault, etc.).

# ---------- AM (where the server talks to ForgeRock AM) ----------
AM_BASE_URL=https://forgeops.example.com/am
AM_REALM=root                        # ForgeOps 2025.2.1 only configures root by default; create alpha via the MCP itself.
AM_ADMIN_USER=amadmin
AM_INSECURE_TLS=true                 # accept the self-signed ForgeOps cert; never set true in prod
# AM_ADMIN_PASSWORD is generated by forgeops at install time. Write it here:
#   kubectl get secret am-env-secrets -n identity -o jsonpath='{.data.AM_PASSWORDS_AMADMIN_CLEAR}' | base64 -d
AM_ADMIN_PASSWORD=

# ---------- MCP server auth (gates who can call the MCP) ----------
# MCP_AUTH_MODE values:
#   - static (default): per-call _authToken matched (constant-time) against the
#     issued tokens below. Needs a tokens file and/or MCP_SERVER_TOKEN.
#   - oauth-am (NOT IMPLEMENTED): bearer per call, introspected via AM, scope-checked.
#   - disabled (TESTING ONLY): also requires MCP_AUTH_DISABLED_ACK=true.
MCP_AUTH_MODE=static

# ---- Scoped tokens (privilege control) ----
# Privileges are hierarchical: read < write < delete. A token granted "write"
# can also read; "delete" can do everything. Each MCP tool is tagged with the
# single privilege it needs (the six delete_* tools require "delete"; create/
# update/upsert require "write"; list/get require "read").
#
# Issue tokens in a JSON file of [{name, token, privileges:[...]}]. The "name"
# is recorded in logs/tool-usage.log so you see which token made each call.
# Copy env/tokens.json.example -> env/tokens.json and fill in real secrets:
#   openssl rand -base64 24 | tr -d '+/='     # per token
# Override the path if you keep it elsewhere (absolute or cwd-relative):
# MCP_TOKENS_FILE=env/tokens.json             # default: mcp-server/env/tokens.json

# Legacy single full-access token. Still supported and treated as a "delete"
# (full-access) token, so existing agent setups keep working. Leave unset once
# you've moved to the scoped tokens file. The agent stores its copy as
# FORGEROCK_AGENT_TOKEN in agent/env/.env; ops/scripts/gen-token.sh writes both.
MCP_SERVER_TOKEN=

# ---------- Tool-usage logging (audit trail of agent tool calls) ----------
# One JSONL line per tool call: ts, transport, tool, permission, status,
# durationMs, argKeys (+ redacted args when MCP_LOG_ARGS=true), error.
# Never written to stdout (that's the MCP transport) — file and/or stderr only.
MCP_LOG_TOOL_USAGE=true              # set false to disable the JSONL file sink
# MCP_LOG_FILE=/abs/path/usage.log   # override path; off/none/empty disables the file sink
                                     # default: mcp-server/logs/tool-usage.log
MCP_LOG_ARGS=false                   # true → include redacted arg VALUES (keys are always logged)
MCP_LOG_STDERR=true                  # set false to silence the concise stderr mirror line
