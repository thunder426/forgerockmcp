# Agent-side runtime config. Copy to agent/env/.env and fill in.
#
# This file belongs to the AGENT side only. The MCP server must not read it.
# The two sides share a secret value but each holds its own copy independently.
#
# In dev, ops/scripts/gen-token.sh writes this file alongside its server-side
# counterpart. In prod, the agent operator provisions it through whatever
# secret-management mechanism they use.

# Must equal MCP_SERVER_TOKEN in mcp-server/env/.env. The agent passes this as
# _authToken on every tool call.
FORGEROCK_AGENT_TOKEN=
